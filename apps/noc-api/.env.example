# Database
# Local: postgresql://user:password@localhost:5432/noc_monitoring
# Docker: postgresql://postgres:postgres@localhost:5432/noc_monitoring
# Supabase/Neon: postgresql://user:password@host:5432/noc_monitoring
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noc_monitoring

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-strong-random-secret-key
BETTER_AUTH_URL=http://localhost:3001

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
